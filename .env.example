# AlertNotes Configuration
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────────────────
# Slack bot token (xoxb-...)
# Create at https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack channel ID or name where alerts are posted
# e.g. C1234567890 or #incidents
SLACK_ALERTS_CHANNEL=#incidents

# ── Optional ──────────────────────────────────────────────
# Slack channel to pull incident context messages from
# (defaults to SLACK_ALERTS_CHANNEL if not set)
SLACK_INCIDENT_CHANNEL=#incidents

# GitHub personal access token for commit context enrichment
# Needs repo:read scope
GITHUB_TOKEN=

# GitHub repo to look up commits (format: org/repo)
GITHUB_REPO=

# Public URL of this AlertNotes instance
# Used to generate links in Slack messages
ALERTNOTES_BASE_URL=http://localhost:8000